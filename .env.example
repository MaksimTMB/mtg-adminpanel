# ─────────────────────────────────────────────────────────────
#  MTG AdminPanel — файл конфигурации
#  Скопируй в .env и заполни своими значениями:
#    cp .env.example .env
# ─────────────────────────────────────────────────────────────

# Пароль для входа в панель управления.
# Придумай надёжный (минимум 12 символов, буквы + цифры).
# Именно этот пароль вводится на странице входа.
AUTH_TOKEN=your-strong-password-here

# Порт, на котором запускается веб-интерфейс панели.
# Если порт 3000 занят — поменяй на любой свободный (например, 8080).
PORT=3000

# Директория для хранения базы данных SQLite.
# Не менять без необходимости — данные хранятся в ./data/ на хосте.
DATA_DIR=/data

# Порт MTG Agent на каждой ноде.
# Должен совпадать со значением, которое вводилось при установке агента.
AGENT_PORT=8081

# Секретный токен для авторизации MTG Agent на нодах.
# Должен быть одинаковым на всех нодах и в этом файле.
# Поменяй на случайную строку (например: openssl rand -hex 16).
AGENT_TOKEN=mtg-agent-secret
